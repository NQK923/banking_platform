BANKING_POSTGRES_PASSWORD=replace-with-local-postgres-password
BANKING_JWT_SECRET=replace-with-at-least-32-random-characters
INTERNAL_SERVICE_TOKEN=replace-with-random-internal-service-token
BANKING_SEED_ADMIN_PASSWORD=replace-with-local-admin-password
BANKING_SEED_ADMIN_PIN=replace-with-local-admin-pin
